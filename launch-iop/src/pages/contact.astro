---
import Base from "../layouts/Base.astro";
const title = "Contact & Referrals | Launch IOP Houston";
const description = "Get in touch with Launch IOP in Houston, TX. Call 713-482-1590 or email info@launchiop.com. Referring clinicians welcome.";
---
<Base title={title} description={description} path="/contact">
  <section class="page-hero">
    <div class="wrap">
      <p class="eyebrow">Get Started</p>
      <h1>Take the <em>first step</em></h1>
      <p>Call or send a note and our intake coordinator will reach out. Clinicians referring a client are welcome too — we work alongside referring therapists in a time-limited, specific role.</p>
    </div>
  </section>

  <section class="cta-final rule-top">
    <div class="wrap cta-grid reveal">
      <div>
        <p class="eyebrow" style="color:var(--taupe)">Reach us</p>
        <h2>We're here to <em>help</em></h2>
        <p>The best first step is a quick call. We'll listen, answer your questions, and help you figure out whether Launch is the right fit — no pressure.</p>
        <a href="tel:7134821590" class="btn btn-light" style="margin-top:12px;">Call 713-482-1590</a>
      </div>
      <div class="contact-card">
        <div class="row"><div class="lbl">Phone</div><a href="tel:7134821590">713-482-1590</a></div>
        <div class="row"><div class="lbl">Email</div><a href="mailto:info@launchiop.com">info@launchiop.com</a></div>
        <div class="row"><div class="lbl">Visit</div><a href="https://maps.google.com/?q=4646+Wild+Indigo+Street+Suite+150+Houston+TX+77027" target="_blank" rel="noopener" style="line-height:1.5;">4646 Wild Indigo Street, Suite 150<br>Houston, TX 77027</a></div>
      </div>
    </div>
  </section>
</Base>
