---
import Base from "../layouts/Base.astro";
const title = "How It Works | The Launch IOP Approach | Houston";
const description = "Launch IOP runs 3-5 days a week, 3-4 hours a day, over 8-12 weeks through three phases: Lift-Off, Ascent, and Orbit. A guided trajectory toward independence.";
---
<Base title={title} description={description} path="/how-it-works">
  <section class="page-hero">
    <div class="wrap">
      <p class="eyebrow">How It Works</p>
      <h1>A guided trajectory toward <em>independence</em></h1>
      <p>Structured enough to create momentum, flexible enough to fit real life. Participants live at home while progressing through three clear phases.</p>
    </div>
  </section>

  <section class="rule-top">
    <div class="wrap reveal">
      <div class="cadence">
        <div><div class="big">3&ndash;5</div><div class="lbl">days / week</div></div>
        <div><div class="big">3&ndash;4</div><div class="lbl">hours / day</div></div>
        <div><div class="big">8&ndash;12</div><div class="lbl">weeks total</div></div>
      </div>
      <div class="phases">
        <div class="phase"><div class="pn">i</div><h3>Lift-Off</h3><div class="wks">Weeks 1&ndash;2</div><p>Assessment, building readiness, and securing the first small wins that create momentum.</p></div>
        <div class="phase"><div class="pn">ii</div><h3>Ascent</h3><div class="wks">Weeks 3&ndash;8</div><p>Skill-building, exposure practice, and real-world challenges that stretch comfort zones.</p></div>
        <div class="phase"><div class="pn">iii</div><h3>Orbit</h3><div class="wks">Weeks 9&ndash;12</div><p>Transition planning, education or work placement, and sustaining independence on your own.</p></div>
      </div>
    </div>
  </section>

  <section class="rule-top">
    <div class="wrap reveal">
      <div class="section-head center"><p class="eyebrow">Our framework</p><h2>The pillars of Launch &mdash; <em>REACH</em></h2></div>
      <div class="reach">
        <div class="pillar"><div class="letter">R</div><div class="word">Resilience</div><div class="desc">Recover from setbacks</div></div>
        <div class="pillar"><div class="letter">E</div><div class="word">Engagement</div><div class="desc">Re-enter daily life</div></div>
        <div class="pillar"><div class="letter">A</div><div class="word">Autonomy</div><div class="desc">Act independently</div></div>
        <div class="pillar"><div class="letter">C</div><div class="word">Connection</div><div class="desc">Build relationships</div></div>
        <div class="pillar"><div class="letter">H</div><div class="word">Health</div><div class="desc">Care for mind &amp; body</div></div>
      </div>
    </div>
  </section>
</Base>
