---
import Base from "../layouts/Base.astro";
const title = "Failure to Launch IOP Program & Cost | Launch IOP Houston";
const description = "Inside the Launch IOP program: individual and family therapy, process and group work, ACT/DBT/CBT, and executive-function coaching. $1,500/week, 10+ hours of care.";
---
<Base title={title} description={description} path="/program">
  <section class="page-hero">
    <div class="wrap">
      <p class="eyebrow">The Program</p>
      <h1>A full week of <em>coordinated care</em></h1>
      <p>Every week at Launch includes at least ten hours of evidence-based treatment from a multidisciplinary team, built around your goals and progress.</p>
    </div>
  </section>

  <section class="rule-top">
    <div class="wrap reveal">
      <div class="section-head"><p class="eyebrow">What's included</p><h2>Core services</h2></div>
      <div class="components">
        <div class="comp"><span class="cn">01</span>Individual Therapy</div>
        <div class="comp"><span class="cn">02</span>Family Therapy</div>
        <div class="comp"><span class="cn">03</span>Interpersonal Process Group</div>
        <div class="comp"><span class="cn">04</span>Behavioral Therapy &mdash; ACT, DBT, CBT</div>
        <div class="comp"><span class="cn">05</span>Executive-Function Coaching</div>
        <div class="comp"><span class="cn">06</span>Group Therapy</div>
      </div>
      <p class="opt-note"><strong>Optional add-on services:</strong> Psychological Assessment &middot; Vocational Assessment &middot; EMDR &middot; CBT-I for insomnia &middot; Ketamine-Assisted Therapy &middot; Couples Therapy.</p>
    </div>
  </section>

  <section class="rule-top">
    <div class="wrap reveal">
      <div class="cost">
        <div>
          <p class="eyebrow" style="color:var(--taupe)">Transparent pricing</p>
          <h2>Clear cost, <em>no surprises</em></h2>
          <div class="price">$1,500<span> / week</span></div>
          <p style="margin-top:14px;">Includes at least 10 hours of treatment per week. Optional services are billed separately.</p>
        </div>
        <div>
          <ul>
            <li>10+ hours of treatment every week</li>
            <li>Coordinated care from a full clinical team</li>
            <li>Itemized invoices (superbills) provided</li>
            <li>Submit for possible out-of-network reimbursement</li>
          </ul>
          <p style="font-size:0.9rem;">Launch does not bill insurance directly at this time.</p>
        </div>
      </div>
    </div>
  </section>
</Base>
