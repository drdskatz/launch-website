---
import Base from "../layouts/Base.astro";
const title = "Our Clinical Team | Launch IOP Houston";
const description = "Meet the licensed clinicians behind Launch IOP — therapists and psychologists who specialize in helping young adults in Houston build independence.";

const members = [
  { initials: "DK", name: "Daniel Katz, Psy.D.", role: "Co-Founder" },
  { initials: "AB", name: "Adam Brownstein, LPC", role: "Co-Founder" },
  { initials: "CC", name: "Claire Cooper, LCSW", role: "Clinical Director" },
  { initials: "SM", name: "Shea McTaggart, Psy.D.", role: "Assessment" },
  { initials: "ES", name: "Elizabeth Seabolt-Esparza, LPC", role: "Therapist" },
  { initials: "EB", name: "Emma Barr, LPA", role: "Assessment & Therapy" },
  { initials: "DB", name: "Dana Boyko, LCSW", role: "Therapist" },
  { initials: "JB", name: "Joe Bartolotta, MBA, LMSW", role: "Therapist" },
];

const schema = {
  "@context": "https://schema.org",
  "@type": "MedicalClinic",
  "name": "Launch IOP",
  "url": "https://www.launchiop.com",
  "employee": members.map((m) => ({
    "@type": "Person",
    "name": m.name.split(",")[0],
    "jobTitle": m.role,
  })),
};
---
<Base title={title} description={description} path="/team" schema={schema}>
  <section class="page-hero">
    <div class="wrap">
      <p class="eyebrow">Meet the Team</p>
      <h1>Licensed clinicians who specialize in <em>young adults</em></h1>
      <p><span class="placeholder-note">Editable later in your CMS</span> &nbsp; Full bios and credentials will live on individual pages for trust &amp; search.</p>
    </div>
  </section>

  <section class="rule-top">
    <div class="wrap reveal">
      <div class="team">
        {members.map((m) => (
          <div class="member">
            <div class="ph">{m.initials}</div>
            <div class="name">{m.name}</div>
            <div class="role">{m.role}</div>
          </div>
        ))}
      </div>
    </div>
  </section>
</Base>
