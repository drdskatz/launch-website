---
import Base from "../layouts/Base.astro";
import fs from "node:fs";
import yaml from "js-yaml";

const title = "Our Clinical Team | Launch IOP Houston";
const description = "Meet the licensed clinicians behind Launch IOP — therapists and psychologists who specialize in helping young adults in Houston build independence.";

const teamDir = "src/content/team";
let members = [];
if (fs.existsSync(teamDir)) {
  members = fs
    .readdirSync(teamDir)
    .filter((f) => f.endsWith(".yaml"))
    .map((f) => {
      const slug = f.replace(/\.yaml$/, "");
      const data = yaml.load(fs.readFileSync(`${teamDir}/${f}`, "utf-8")) || {};
      const name = data.name || "";
      let photo = data.photo || "";
      if (photo && !photo.startsWith("/") && !photo.startsWith("http")) {
        photo = "/images/team/" + photo;
      }
      const initials = name
        .replace(/,.*$/, "")
        .split(/\s+/)
        .filter(Boolean)
        .slice(0, 2)
        .map((w) => w[0])
        .join("")
        .toUpperCase();
      return {
        slug,
        name,
        role: data.title || "",
        photo,
        order: typeof data.order === "number" ? data.order : 0,
        initials,
      };
    })
    .sort((a, b) => a.order - b.order || a.name.localeCompare(b.name));
}

const schema = {
  "@context": "https://schema.org",
  "@type": "MedicalClinic",
  "name": "Launch IOP",
  "url": "https://www.launchiop.com",
  "employee": members.map((m) => ({
    "@type": "Person",
    "name": m.name.split(",")[0],
    "jobTitle": m.role,
    "url": `https://www.launchiop.com/team/${m.slug}`,
  })),
};
---
<Base title={title} description={description} path="/team" schema={schema}>
  <section class="page-hero">
    <div class="wrap">
      <p class="eyebrow">Meet the Team</p>
      <h1>Licensed clinicians who specialize in <em>young adults</em></h1>
      <p>Each clinician brings specialized training in young-adult mental health. Select a clinician to read their full bio.</p>
    </div>
  </section>

  <section class="rule-top">
    <div class="wrap reveal">
      <div class="team">
        {members.map((m) => (
          <a class="member" href={`/team/${m.slug}`}>
            {m.photo
              ? <img class="ph" src={m.photo} alt={m.name} width="120" height="120" />
              : <div class="ph">{m.initials}</div>}
            <div class="name">{m.name}</div>
            <div class="role">{m.role}</div>
          </a>
        ))}
      </div>
    </div>
  </section>
</Base>
